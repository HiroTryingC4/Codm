generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Game (MP|BR), TryoutType (COMPETITIVE|CASUAL), Mode (SOLO|TEAM|DUO|SQUAD),
// status (PENDING|REVIEWED|ACCEPTED|REJECTED) are plain strings validated in
// application code — see src/types/index.ts for the TS unions.
// (Kept as strings rather than native Postgres enums since the schema started on SQLite,
// which has no enum support — no need to churn it now that both work.)

model Applicant {
  id           String @id @default(cuid())
  game         String @default("MP")
  inGameName   String
  uid          String
  fbName       String  @default("")
  cityProvince String  @default("")
  streamerMode String?
  tryoutType   String
  mode         String
  teamName     String?
  role         String?
  motivation   String
  recruitedBy  String?
  status       String @default("PENDING")

  comments  Comment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Comment {
  id          String    @id @default(cuid())
  applicantId String
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  adminId     String
  admin       Admin     @relation(fields: [adminId], references: [id])
  text        String
  createdAt   DateTime  @default(now())
}

model Admin {
  id           String   @id @default(cuid())
  name         String   @unique
  passwordHash String
  role         String // "HEAD" | "ADMIN" — see src/types/index.ts AdminRole
  createdAt    DateTime @default(now())

  comments Comment[]
}
