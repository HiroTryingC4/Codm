# Postgres connection string (Neon, via the Vercel integration, or any Postgres host)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# random secret used to sign the admin session cookie
ADMIN_SESSION_SECRET=""

# Admin accounts are stored in the DB, not env vars. After the first migration,
# create the one head admin account with:
#   node scripts/create-head-admin.js "Name" "password"
# The head can then create further (non-head) accounts from /admin/accounts.
